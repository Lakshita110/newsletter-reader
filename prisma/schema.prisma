generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RssPriority {
  HIGH
  NORMAL
  LOW
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  messages         Message[]
  messageReadStats MessageReadStat[]
  rssSubscriptions UserRssSubscription[]
}

model Source {
  id            String    @id @default(cuid())
  name         String
  normalizedKey String
  senderDomain String?
  senderEmail  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]

  @@unique([normalizedKey, senderEmail])
  @@index([normalizedKey])
}

model Message {
  id             String            @id @default(cuid())
  userId        String
  sourceId      String?
  gmailMessageId String
  gmailThreadId String?
  subject       String
  fromRaw       String
  dateHeader    String?
  sentAt        DateTime?
  snippet       String?
  htmlRaw       String?       @db.Text
  textExtracted String?       @db.Text
  contentHash   String?
  isNewsletter   Boolean           @default(true)
  fetchedAt      DateTime          @default(now())
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  source         Source?           @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@unique([userId, gmailMessageId])
  @@index([userId, sentAt])
  @@index([sourceId, sentAt])
  @@index([contentHash])
}

model MessageReadStat {
  id                 String   @id @default(cuid())
  userId             String
  messageExternalId  String
  messageTitle       String?
  sourceKind         String?
  publicationName    String?
  firstOpenedAt      DateTime?
  lastOpenedAt       DateTime?
  openCount          Int      @default(0)
  totalSecondsRead   Int      @default(0)
  maxScrollPct       Float    @default(0)
  completionPct      Float    @default(0)
  completedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, messageExternalId])
  @@index([userId, lastOpenedAt])
  @@index([messageExternalId])
}

model RssSource {
  id            String                @id @default(cuid())
  name          String
  rssUrl        String                @unique
  normalizedUrl String                @unique
  siteUrl       String?
  isActive      Boolean               @default(true)
  lastSyncedAt  DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  items         RssItem[]
  subscriptions UserRssSubscription[]

  @@index([normalizedUrl])
}

model UserRssSubscription {
  id          String      @id @default(cuid())
  userId      String
  rssSourceId String
  isActive    Boolean     @default(true)
  priority    RssPriority @default(NORMAL)
  dailyCap    Int         @default(2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  source      RssSource   @relation(fields: [rssSourceId], references: [id], onDelete: Cascade)

  @@unique([userId, rssSourceId])
  @@index([userId, isActive])
}

model RssItem {
  id           String    @id @default(cuid())
  rssSourceId  String
  externalId   String
  title        String
  author       String?
  link         String?
  imageUrl     String?
  publishedAt  DateTime?
  snippet      String?
  htmlRaw      String?   @db.Text
  textExtracted String?  @db.Text
  contentHash  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  source       RssSource @relation(fields: [rssSourceId], references: [id], onDelete: Cascade)

  @@unique([rssSourceId, externalId])
  @@index([rssSourceId, publishedAt])
}
