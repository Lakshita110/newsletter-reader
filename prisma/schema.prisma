generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RssPriority {
  HIGH
  NORMAL
  LOW
}

enum RssRankSnapshotStatus {
  AI_SUCCESS
  FALLBACK_DETERMINISTIC
}

enum RssRankSnapshotSource {
  CRON
  ON_DEMAND
}

model User {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  rssRecommendationCap     Int                       @default(35)
  rssRecommendationPrompt  String?                   @db.VarChar(500)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  messageReadStats         MessageReadStat[]
  rssSubscriptions         UserRssSubscription[]
  rssRankSnapshots         UserRssDailyRankSnapshot[]
  rssRankLocks             UserRssRankJobLock[]
  rssReadProfileSnapshot   UserRssReadProfileSnapshot?
}

model MessageReadStat {
  id                 String   @id @default(cuid())
  userId             String
  messageExternalId  String
  messageTitle       String?
  sourceKind         String?
  publicationName    String?
  firstOpenedAt      DateTime?
  lastOpenedAt       DateTime?
  openCount          Int      @default(0)
  totalSecondsRead   Int      @default(0)
  maxScrollPct       Float    @default(0)
  completionPct      Float    @default(0)
  completedAt        DateTime?
  savedAt            DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, messageExternalId])
  @@index([userId, lastOpenedAt])
  @@index([userId, savedAt])
  @@index([messageExternalId])
}

model RssSource {
  id            String                @id @default(cuid())
  name          String
  rssUrl        String                @unique
  normalizedUrl String                @unique
  siteUrl       String?
  isActive      Boolean               @default(true)
  lastSyncedAt  DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  items         RssItem[]
  subscriptions UserRssSubscription[]

  @@index([normalizedUrl])
}

model UserRssSubscription {
  id          String      @id @default(cuid())
  userId      String
  rssSourceId String
  isActive    Boolean     @default(true)
  category    String      @default("other")
  priority    RssPriority @default(NORMAL)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  source      RssSource   @relation(fields: [rssSourceId], references: [id], onDelete: Cascade)

  @@unique([userId, rssSourceId])
  @@index([userId, isActive])
}

model RssItem {
  id           String    @id @default(cuid())
  rssSourceId  String
  externalId   String
  title        String
  author       String?
  link         String?
  imageUrl     String?
  publishedAt  DateTime?
  snippet      String?
  htmlRaw      String?   @db.Text
  textExtracted String?  @db.Text
  contentHash  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  source       RssSource @relation(fields: [rssSourceId], references: [id], onDelete: Cascade)

  @@unique([rssSourceId, externalId])
  @@index([rssSourceId, publishedAt])
}

model UserRssDailyRankSnapshot {
  id               String                @id @default(cuid())
  userId           String
  dayKey           String
  rankedItemIds    Json
  status           RssRankSnapshotStatus
  source           RssRankSnapshotSource
  model            String?
  inputFingerprint String
  expiresAt        DateTime
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey])
  @@index([dayKey, expiresAt])
}

model UserRssRankJobLock {
  id        String   @id @default(cuid())
  userId    String
  dayKey    String
  ownerId   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey])
  @@index([dayKey, expiresAt])
}

model UserRssReadProfileSnapshot {
  id                String   @id @default(cuid())
  userId            String   @unique
  weekKey           String
  topPublications   Json
  avgCompletionPct  Float
  recentReadCount7d Int
  preferenceSummary Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([weekKey, updatedAt])
}
